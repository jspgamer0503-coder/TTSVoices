# Auto-detect text files
* text=auto

# Force LF line endings for shell scripts and Python
*.sh        text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary files
*.so        binary
*.png       binary
*.jpg       binary
*.ico       binary
*.wav       binary
*.mp3       binary
